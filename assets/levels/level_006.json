  "assembly": {
    "title": "第六关管道组装说明",
    "goal": "用64个管道模块搭建Z字形主路，干扰模块集中在中部空间。",
    "steps": [
      "先从(0,0,0)沿z方向摆到(0,0,3)。",
      "再沿x方向摆到(3,0,3)，最后沿y方向进入终点。",
      "将6个干扰模块摆成两段短假路，避免连接到终点。",
      "核对64个模块后，使用钢珠完成挑战。"
    ]
  },
