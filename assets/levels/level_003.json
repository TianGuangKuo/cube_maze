  "assembly": {
    "title": "第三关管道组装说明",
    "goal": "用64个管道模块搭建三次转向的折线路径，干扰块会制造相似的短折线。",
    "steps": [
      "先摆放z=0层底边主通路，再沿z方向抬升到z=3。",
      "确认主通路最后沿y方向进入(3,3,3)。",
      "将6个干扰模块摆在非主通路区域，形成看似连续但无法到终点的短线。",
      "检查起点和终点位置无误后开始挑战。"
    ]
  },
