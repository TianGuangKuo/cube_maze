  "assembly": {
    "title": "第七关管道组装说明",
    "goal": "用64个管道模块搭建跨层空间路径，干扰块会遮蔽真实转向。",
    "steps": [
      "按主通路编号从起点逐个摆放，注意每次跨z层的位置变化。",
      "主路会在x、y、z三个方向频繁转向，摆放后逐段检查开口是否相对。",
      "把4个干扰模块摆在低层和中层，形成两个短假通路。",
      "总数核对为64个后再开始钢珠挑战。"
    ]
  },
